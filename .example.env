# backend
DATABASE_URL=sqlite:///./app.db
API_HOST=127.0.0.1
API_PORT=8000
API_BASE=http://127.0.0.1:8000

# Runner selection (optional default)
DEFAULT_RUNNER=local
# Databricks (only needed if using databricks runner)
DATABRICKS_HOST=
DATABRICKS_TOKEN=
DATABRICKS_JOB_ID=

AZURE_STORAGE_ACCOUNT=
AZURE_RESULTS_CONTAINER=results
AZURE_RESULTS_PREFIX=export
# How your local code authenticates to ADLS (choose ONE method)
# Option 1: Account key (toy simplest)
AZURE_STORAGE_KEY=<storage_account_key>
# Airflow (only needed if using airflow runner)
AIRFLOW_BASE_URL=
AIRFLOW_DAG_ID=
AIRFLOW_USER=
AIRFLOW_PASSWORD=

# JWT
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=60

# Simple demo users (comma-separated roles)
DEMO_USER_USERNAME=demo
DEMO_USER_PASSWORD=demo123
DEMO_USER_ROLES=viewer,submitter
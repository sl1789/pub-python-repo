# backend
DATABASE_URL=sqlite:///./app.db
API_HOST=127.0.0.1
API_PORT=8000
API_BASE=http://127.0.0.1:8000
APP_AUTO_CREATE_TABLES=true

# Databricks (required to submit Monte Carlo jobs)
DATABRICKS_HOST=
DATABRICKS_TOKEN=
DATABRICKS_MC_JOB_ID=

# Azure ADLS Gen2 (Monte Carlo parquet export)
AZURE_STORAGE_ACCOUNT=
AZURE_RESULTS_CONTAINER=results
# Must match EXPORT_PREFIX configured in databricks/src/config/settings.py
AZURE_MC_RESULTS_PREFIX=export/simulations
AZURE_STORAGE_KEY=<storage_account_key>

# JWT
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=60

# Demo user
DEMO_USER_USERNAME=demo
DEMO_USER_PASSWORD=demo123
DEMO_USER_ROLES=viewer,submitter
